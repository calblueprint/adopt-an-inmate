# Supabase
NEXT_PUBLIC_SUPABASE_URL= # The publicly exposable Supabase URL
NEXT_PUBLIC_SUPABASE_ANON_KEY= # The anonymous key used for accessing the public database
PROJECT_ID= # Supabase project ID for generating types during development
DATABASE_URL= # The database connection string, used by the vector database client
SUPABASE_SERVICE_KEY= # The service role key used for automated admin services

# Brevo SMTP
BREVO_SMTP_USER= # From Brevo: SMTP & API → SMTP → Username/Login
BREVO_SMTP_KEY= # From Brevo: SMTP & API → SMTP → SMTP key
EMAIL_SENDER_NAME= # Sender display name in emails (optional; defaults to "Adopt an Inmate Team")

