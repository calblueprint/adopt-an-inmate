# The publicly exposable Supabase URL
NEXT_PUBLIC_SUPABASE_URL=

# The anonymous key used for accessing the public database
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase project ID for generating types during development
PROJECT_ID=

# Brevo SMTP (smtp-relay.brevo.com:587) — set these in .env; do not commit real values
# From Brevo: SMTP & API → SMTP → Username/Login
BREVO_SMTP_USER=
# From Brevo: SMTP & API → SMTP → SMTP key
BREVO_SMTP_KEY=
# Sender display name in emails (optional; defaults to "Adopt an Inmate Team")
EMAIL_SENDER_NAME=

# Monday.com
MONDAY_API_TOKEN=
MONDAY_ADOPTER_DATA_BOARD_ID=
MONDAY_ADOPTER_DATA_WAITING_GROUP_ID=
